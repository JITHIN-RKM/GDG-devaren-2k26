## Cloud AI (OpenAI-compatible)
# Base URL for your provider. Examples:
# - https://api.openai.com/v1
# - https://api.groq.com/openai/v1
# - https://api.together.xyz/v1
# - https://integrate.api.nvidia.com/v1
VITE_AI_BASE_URL=https://api.openai.com/v1

# Your provider API key (DO NOT COMMIT a real key)
VITE_AI_API_KEY=your_api_key_here

# Model name for your provider
VITE_AI_MODEL=gpt-4o-mini

# Optional tuning
VITE_AI_MAX_TOKENS=2048
VITE_AI_TEMPERATURE=0.7
VITE_AI_TOP_P=0.95

# NVIDIA supports this flag (optional)
VITE_AI_ENABLE_THINKING=false

